# ─────────────────────────────────────────────────────────
# GitNova Backend - Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# Neon PostgreSQL connection string (required)
# Get yours free at https://neon.tech
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.db/dbname?sslmode=require"

# ── Authentication ───────────────────────────────────────
# JWT signing secret — MUST be a long, random string in production
# Generate one: openssl rand -base64 32
JWT_SECRET="your-secure-random-string-here"

# ── Server ───────────────────────────────────────────────
# Port the Express server listens on
PORT=3001

# ── CORS ─────────────────────────────────────────────────
# Comma-separated allowed origins. Must match your frontend URL(s).
# Production example: https://gitnova.vercel.app
# Local dev example:  http://localhost:5173
CORS_ORIGIN="https://your-domain.vercel.app"

# ── Monitoring (optional) ────────────────────────────────
# Sentry DSN for error tracking — leave empty to disable
SENTRY_DSN=""
